# Copia este archivo a .env.local para desarrollo en tu PC:
#   cp .env.example .env.local   (o créalo manualmente)
#
# Vite carga .env.local en "npm run dev" y tiene prioridad sobre .env.production.

# --- Local (backend en tu máquina) ---
VITE_API_URL=http://127.0.0.1:8000

# --- Producción (Amplify: Environment variables, NO subir .env.production al repo) ---
# Copia .env.production.example y configura en la consola de Amplify:
# VITE_API_URL=https://tu-api.elasticbeanstalk.com
