# Copia a .env y ajusta valores (.env no se sube a git)

# --- LOCAL recomendado: SQLite (cero configuración extra) ---
DATABASE_URL=sqlite:///./pos_cafeteria.db

# --- LOCAL alternativo: PostgreSQL en tu PC ---
# DATABASE_URL=postgresql+psycopg2://usuario:password@localhost:5432/cafeteria_db

# --- PRODUCCIÓN: RDS (configurar en Elastic Beanstalk, no en .env del repo) ---
# DATABASE_URL=postgresql+psycopg2://usuario:password@host.rds.amazonaws.com:5432/cafeteria_db

SECRET_KEY=cambia-esta-clave-en-local
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Solo SQLite local: credenciales del primer admin si la BD está vacía
LOCAL_ADMIN_LOGIN=admin
LOCAL_ADMIN_PASSWORD=admin123
