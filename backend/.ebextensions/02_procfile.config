# Fuerza Procfile ASGI: EB a veces genera uno WSGI (gthread) e ignora el del repo
container_commands:
  01_write_procfile:
    command: |
      printf '%s\n' 'web: gunicorn -k uvicorn.workers.UvicornWorker app.main:app --bind 0.0.0.0:8000 --workers 2 --timeout 120' > Procfile
      cat Procfile
    cwd: /var/app/staging
